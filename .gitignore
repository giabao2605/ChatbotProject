# ==============================================================================
# .gitignore — Mechanical Engineering RAG Chatbot
# ==============================================================================

# ===== Python virtual environments =====
chat_env/
source/
venv/
.venv/
env/
ENV/
**/pyvenv.cfg
**/site-packages/

# ===== Python cache & build =====
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
*.whl
*.egg

# ===== Node / Vue frontend (web-ui/) =====
node_modules/
web-ui/dist/
web-ui/.vite/
web-ui/.vitest/
web-ui/coverage/
web-ui/playwright-report/
web-ui/test-results/
*.tsbuildinfo

# ===== Testing & QA =====
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml
.coverage.*
.tox/
.nox/
test-results/
playwright-report/
blob-report/

# ===== Data (raw, processed & cache — large/generated files) =====
data/raw/
data/processed/
data/cache/
src/data/processed/

# ===== Logs & Traces =====
logs/
temp_logs/
*.log
rag_trace.jsonl

# ===== Generated Reports =====
reports/
*.prof
*.lprof

# ===== Secrets & Environment =====
.env
.env.*
!.env.example
.streamlit/secrets.toml

# ===== Streamlit config (legacy) =====
.streamlit/

# ===== Debug & Temp scripts =====
debug*.py
debug*.txt
temp_*.py
temp_*.txt
tmp/
temp/
plot.log

# ===== IDE & OS =====
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db
.DS_Store
desktop.ini
*.stackdump

# ===== Local agent/Codex workspace state =====
# Keep repository skills and instructions under .agents/ in version control.
.agents/state/
.agents/cache/
.codex/

# ===== Temp RAG worker files =====
rag_in_*.json
rag_out_*.json
*.pid

# ===== Refactor scripts (one-time use) =====
refactor_project.py

# ===== Stale / accidental directories =====
# "True/" directory sometimes created by buggy path logic
True/

# ===== Model / Embedding cache (sentence-transformers, HuggingFace) =====
.cache/
.hf_cache/
huggingface/
sentence_transformers/
models/cache/

# ===== Local databases, exports & backups =====
*.bak
*.bacpac
*.bcp
*.dump
*.sqlite
*.sqlite3
*.mdf
*.ndf
*.ldf

# ===== Local upload/session artifacts =====
uploads/
sessions/
.local/
data/demo_wave_v1/
reports/demo_wave/
*.tmp
*.tmp.*

# ===== Archive (historical/deprecated scripts) =====
archive/

# ===== Empty components directory (legacy placeholder) =====
components/
