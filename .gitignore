# ==============================================================================
# .gitignore — Mechanical Engineering RAG Chatbot
# ==============================================================================

# ===== Python virtual environments =====
chat_env/
source/
venv/
.venv/
env/
ENV/
**/pyvenv.cfg
**/site-packages/

# ===== Python cache & build =====
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
*.whl
*.egg

# ===== Testing & QA =====
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

# ===== Data (raw, processed & cache — large/generated files) =====
data/raw/
data/processed/
data/cache/

# ===== Logs & Traces =====
logs/
temp_logs/
*.log
rag_trace.jsonl

# ===== Generated Reports =====
reports/

# ===== Secrets & Environment =====
.env
.env.*
!.env.example
.streamlit/secrets.toml

# ===== Debug & Temp scripts =====
debug*.py
debug*.txt
temp_*.py
temp_*.txt
plot.log

# ===== IDE & OS =====
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db
.DS_Store
desktop.ini

# ===== Local agent/Codex workspace state =====
.agents/
.codex/

# ===== Temp RAG worker files =====
rag_in_*.json
rag_out_*.json

# ===== Refactor scripts (one-time use) =====
refactor_project.py

# ===== Stale / accidental directories =====
# "True/" directory sometimes created by buggy path logic
True/

# ===== Model / Embedding cache (sentence-transformers, HuggingFace) =====
.cache/
models/
*.onnx
*.bin
*.safetensors

# ===== Archive (historical/deprecated scripts) =====
archive/
